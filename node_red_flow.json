[
  {
    "id": "tab_sensor",
    "type": "tab",
    "label": "Sensor Monitor",
    "disabled": false,
    "info": "Real-time sensor dashboard via MySQL"
  },
  {
    "id": "inject_trigger",
    "type": "inject",
    "z": "tab_sensor",
    "name": "Every 2s",
    "props": [{ "p": "payload" }],
    "repeat": "2",
    "crontab": "",
    "once": true,
    "onceDelay": 0.1,
    "topic": "",
    "payload": "",
    "payloadType": "date",
    "x": 120,
    "y": 120,
    "wires": [["mysql_query"]]
  },
  {
    "id": "mysql_query",
    "type": "mysql",
    "z": "tab_sensor",
    "name": "sensor_db query",
    "mydb": "mysql_config",
    "query": "SELECT timestamp, temperature, humidity, pressure, light_level FROM sensor_data ORDER BY id DESC LIMIT 1;",
    "x": 320,
    "y": 120,
    "wires": [["split_fields", "debug_out"]]
  },
  {
    "id": "split_fields",
    "type": "function",
    "z": "tab_sensor",
    "name": "Split to messages",
    "func": "var row = msg.payload[0];\nif (!row) return null;\nreturn [\n  [{ payload: row.temperature,  topic: 'temperature' }],\n  [{ payload: row.humidity,     topic: 'humidity'    }],\n  [{ payload: row.pressure,     topic: 'pressure'    }],\n  [{ payload: row.light_level,  topic: 'light_level' }],\n  [{ payload: row.timestamp,    topic: 'timestamp'   }]\n];",
    "outputs": 5,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "x": 540,
    "y": 120,
    "wires": [
      ["gauge_temp"],
      ["gauge_hum"],
      ["gauge_press"],
      ["gauge_light"],
      ["text_ts"]
    ]
  },
  {
    "id": "gauge_temp",
    "type": "ui_gauge",
    "z": "tab_sensor",
    "name": "Temperature",
    "group": "group_sensors",
    "order": 1,
    "width": 3,
    "height": 3,
    "gtype": "gage",
    "title": "Temperature",
    "label": "°C",
    "format": "{{value}}",
    "min": 0,
    "max": 50,
    "colors": ["#00b500", "#e6e600", "#ca3838"],
    "seg1": "25",
    "seg2": "35",
    "x": 760,
    "y": 60,
    "wires": []
  },
  {
    "id": "gauge_hum",
    "type": "ui_gauge",
    "z": "tab_sensor",
    "name": "Humidity",
    "group": "group_sensors",
    "order": 2,
    "width": 3,
    "height": 3,
    "gtype": "gage",
    "title": "Humidity",
    "label": "%",
    "format": "{{value}}",
    "min": 0,
    "max": 100,
    "colors": ["#00b500", "#e6e600", "#ca3838"],
    "seg1": "60",
    "seg2": "80",
    "x": 760,
    "y": 120,
    "wires": []
  },
  {
    "id": "gauge_press",
    "type": "ui_gauge",
    "z": "tab_sensor",
    "name": "Pressure",
    "group": "group_sensors",
    "order": 3,
    "width": 3,
    "height": 3,
    "gtype": "gage",
    "title": "Pressure",
    "label": "hPa",
    "format": "{{value}}",
    "min": 950,
    "max": 1050,
    "colors": ["#00b500", "#e6e600", "#ca3838"],
    "seg1": "990",
    "seg2": "1020",
    "x": 760,
    "y": 180,
    "wires": []
  },
  {
    "id": "gauge_light",
    "type": "ui_gauge",
    "z": "tab_sensor",
    "name": "Light Level",
    "group": "group_sensors",
    "order": 4,
    "width": 3,
    "height": 3,
    "gtype": "gage",
    "title": "Light Level",
    "label": "lux",
    "format": "{{value}}",
    "min": 0,
    "max": 1000,
    "colors": ["#0000ff", "#e6e600", "#ca3838"],
    "seg1": "300",
    "seg2": "700",
    "x": 760,
    "y": 240,
    "wires": []
  },
  {
    "id": "text_ts",
    "type": "ui_text",
    "z": "tab_sensor",
    "group": "group_sensors",
    "order": 5,
    "width": 6,
    "height": 1,
    "name": "Last Update",
    "label": "Last Update",
    "format": "{{msg.payload}}",
    "layout": "row-spread",
    "x": 760,
    "y": 300,
    "wires": []
  },
  {
    "id": "chart_temp",
    "type": "ui_chart",
    "z": "tab_sensor",
    "name": "Temp Chart",
    "group": "group_charts",
    "order": 1,
    "width": 6,
    "height": 4,
    "label": "Temperature over time",
    "chartType": "line",
    "legend": "false",
    "xformat": "HH:mm:ss",
    "interpolate": "linear",
    "nodata": "No data",
    "dot": false,
    "ymin": "0",
    "ymax": "50",
    "removeOlder": 1,
    "removeOlderPoints": "60",
    "removeOlderUnit": "3600",
    "cutout": 0,
    "useOneColor": false,
    "colors": ["#e62325"],
    "x": 760,
    "y": 360,
    "wires": []
  },
  {
    "id": "debug_out",
    "type": "debug",
    "z": "tab_sensor",
    "name": "Debug",
    "active": true,
    "tosidebar": true,
    "console": false,
    "tostatus": false,
    "complete": "payload",
    "targetType": "msg",
    "statusVal": "",
    "statusType": "auto",
    "x": 540,
    "y": 220,
    "wires": []
  },
  {
    "id": "mysql_config",
    "type": "MySQLdatabase",
    "name": "sensor_db",
    "host": "127.0.0.1",
    "port": "3306",
    "db": "sensor_db",
    "tz": ""
  },
  {
    "id": "group_sensors",
    "type": "ui_group",
    "name": "Sensor Gauges",
    "tab": "ui_tab_main",
    "order": 1,
    "disp": true,
    "width": "12",
    "collapse": false
  },
  {
    "id": "group_charts",
    "type": "ui_group",
    "name": "Trend Charts",
    "tab": "ui_tab_main",
    "order": 2,
    "disp": true,
    "width": "12",
    "collapse": false
  },
  {
    "id": "ui_tab_main",
    "type": "ui_tab",
    "name": "Sensor Dashboard",
    "icon": "dashboard",
    "order": 1,
    "disabled": false,
    "hidden": false
  }
]
