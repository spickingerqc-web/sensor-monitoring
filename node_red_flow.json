  {
    "id": "n_card",
    "type": "ui_template",
    "z": "tab1",
    "group": "n_grp_card",
    "order": 1,
    "width": 12,
    "height": 3,
    "name": "Status Card",
    "template": "<script>\n(function(scope){\n  scope.d = {};\n  scope.$watch('msg', function(m){ if(m && m.payload) scope.d = m.payload; });\n})(scope);\n</script>\n<div style=\"display:flex;gap:12px;flex-wrap:wrap;padding:8px;\">\n  <div style=\"flex:1;min-width:110px;background:linear-gradient(135deg,#f94144,#f3722c);border-radius:12px;padding:14px;text-align:center;color:#fff;\">\n    <div style=\"font-size:28px;\">\ud83c\udf21\ufe0f</div>\n    <div style=\"font-size:28px;font-weight:bold;\">{{d.temperature | number:1}}\u00b0C</div>\n    <div style=\"font-size:12px;opacity:0.8;\">Temperature</div>\n  </div>\n  <div style=\"flex:1;min-width:110px;background:linear-gradient(135deg,#0077b6,#00b4d8);border-radius:12px;padding:14px;text-align:center;color:#fff;\">\n    <div style=\"font-size:28px;\">\ud83d\udca7</div>\n    <div style=\"font-size:28px;font-weight:bold;\">{{d.humidity | number:1}}%</div>\n    <div style=\"font-size:12px;opacity:0.8;\">Humidity</div>\n  </div>\n  <div style=\"flex:1;min-width:110px;background:linear-gradient(135deg,#1b4332,#52b788);border-radius:12px;padding:14px;text-align:center;color:#fff;\">\n    <div style=\"font-size:28px;\">\ud83c\udf2c\ufe0f</div>\n    <div style=\"font-size:28px;font-weight:bold;\">{{d.pressure | number:1}}</div>\n    <div style=\"font-size:12px;opacity:0.8;\">Pressure hPa</div>\n  </div>\n  <div style=\"flex:1;min-width:110px;background:linear-gradient(135deg,#f8961e,#ffd60a);border-radius:12px;padding:14px;text-align:center;color:#fff;\">\n    <div style=\"font-size:28px;\">\u2600\ufe0f</div>\n    <div style=\"font-size:28px;font-weight:bold;\">{{d.light_level | number:0}}</div>\n    <div style=\"font-size:12px;opacity:0.8;\">Light lux</div>\n  </div>\n</div>",
    "templateScope": "local",
    "storeOutMessages": false,
    "fwd": false,
    "x": 900,
    "y": 400,
    "wires": [
      []
    ]
  },
  {
    "id": "n_table",
    "type": "ui_template",
    "z": "tab1",
    "group": "n_grp_table",
    "order": 1,
    "width": 12,
    "height": 9,
    "name": "Data Table",
    "template": "<script>\n(function(scope){\n  scope.rows = [];\n  scope.$watch('msg', function(m){ if(m && m.payload) scope.rows = m.payload; });\n  scope.tColor = function(v){ return v>35?'#f94144':v>28?'#f8961e':'#43aa8b'; };\n  scope.hColor = function(v){ return v>80?'#48cae4':v>60?'#00b4d8':'#90e0ef'; };\n  scope.lColor = function(v){ return v>700?'#f8961e':v>300?'#ffd60a':'#adb5bd'; };\n})(scope);\n</script>\n<div style=\"overflow-x:auto;\">\n<table style=\"width:100%;border-collapse:collapse;font-size:13px;\">\n  <thead>\n    <tr style=\"background:#1f2937;color:#e5e7eb;position:sticky;top:0;\">\n      <th style=\"padding:8px 10px;text-align:left;\">\ud83d\udd50 Timestamp</th>\n      <th style=\"padding:8px 10px;text-align:center;\">\ud83c\udf21\ufe0f Temp \u00b0C</th>\n      <th style=\"padding:8px 10px;text-align:center;\">\ud83d\udca7 Humid %</th>\n      <th style=\"padding:8px 10px;text-align:center;\">\ud83c\udf2c\ufe0f Press hPa</th>\n      <th style=\"padding:8px 10px;text-align:center;\">\u2600\ufe0f Light lux</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr ng-repeat=\"row in rows track by $index\"\n        ng-style=\"{'background': $index%2===0 ? '#111827' : '#1a2535'}\">\n      <td style=\"padding:6px 10px;color:#9ca3af;\">{{row.timestamp}}</td>\n      <td style=\"padding:6px 10px;text-align:center;font-weight:bold;\"\n          ng-style=\"{'color': tColor(row.temperature)}\">{{row.temperature | number:1}}</td>\n      <td style=\"padding:6px 10px;text-align:center;font-weight:bold;\"\n          ng-style=\"{'color': hColor(row.humidity)}\">{{row.humidity | number:1}}</td>\n      <td style=\"padding:6px 10px;text-align:center;color:#52b788;\">{{row.pressure | number:1}}</td>\n      <td style=\"padding:6px 10px;text-align:center;font-weight:bold;\"\n          ng-style=\"{'color': lColor(row.light_level)}\">{{row.light_level | number:0}}</td>\n    </tr>\n  </tbody>\n</table>\n</div>",
    "templateScope": "local",
    "storeOutMessages": false,
    "fwd": false,
    "x": 900,
    "y": 460,
    "wires": [
      []
    ]
  },
