        "n_setquery"
      ]
    ]
  },
  {
    "id": "n_setquery",
    "type": "function",
    "z": "tab1",
    "name": "Set Query",
    "func": "msg.topic='SELECT timestamp,temperature,humidity,pressure,light_level FROM sensor_data ORDER BY id DESC LIMIT 30';\nreturn msg;",
    "outputs": 1,
    "x": 290,
    "y": 80,
    "wires": [
      [
        "n_mysql"
      ]
    ]
  },
  {
    "id": "n_mysql",
    "type": "mysql",
    "z": "tab1",
    "name": "sensor_db",
    "mydb": "n_dbconfig",
    "x": 480,
    "y": 80,
    "wires": [
      [
        "n_format"
      ]
    ]
  },
  {
    "id": "n_format",
    "type": "function",
    "z": "tab1",
    "name": "Format All",
    "func": "var rows = msg.payload;\nif (!rows || rows.length === 0) return null;\nvar latest = rows[0];\nvar sorted = rows.slice().reverse();\n\nfunction makeChart(field, label) {\n  return { payload: [{ series:[label], data:[sorted.map(function(r){\n    return { x: new Date(r.timestamp).getTime(), y: r[field] };\n  })], labels:[label] }] };\n}\n\n// \ud14c\uc774\ube14 HTML \ubb38\uc790\uc5f4 \uc0dd\uc131\nvar html = '<table style=\"width:100%;border-collapse:collapse;font-size:13px;\">';\nhtml += '<thead><tr style=\"background:#374151;color:#f9fafb;\">';\nhtml += '<th style=\"padding:8px;text-align:left;\">\ud83d\udd50 Timestamp</th>';\nhtml += '<th style=\"padding:8px;text-align:center;\">\ud83c\udf21\ufe0f Temp\u00b0C</th>';\nhtml += '<th style=\"padding:8px;text-align:center;\">\ud83d\udca7 Humid%</th>';\nhtml += '<th style=\"padding:8px;text-align:center;\">\ud83c\udf2c\ufe0f Press hPa</th>';\nhtml += '<th style=\"padding:8px;text-align:center;\">\u2600\ufe0f Light lux</th>';\nhtml += '</tr></thead><tbody>';\nrows.forEach(function(r,i){\n  var bg = i%2===0?'#1f2937':'#111827';\n  var tc = r.temperature>35?'#f87171':r.temperature>28?'#fb923c':'#4ade80';\n  var hc = r.humidity>80?'#60a5fa':r.humidity>60?'#38bdf8':'#7dd3fc';\n  var lc = r.light_level>700?'#fb923c':r.light_level>300?'#facc15':'#94a3b8';\n  html += '<tr style=\"background:'+bg+';\">';\n  html += '<td style=\"padding:5px 8px;color:#9ca3af;font-size:12px;\">'+r.timestamp+'</td>';\n  html += '<td style=\"padding:5px 8px;text-align:center;font-weight:bold;color:'+tc+';\">'+r.temperature.toFixed(1)+'</td>';\n  html += '<td style=\"padding:5px 8px;text-align:center;font-weight:bold;color:'+hc+';\">'+r.humidity.toFixed(1)+'</td>';\n  html += '<td style=\"padding:5px 8px;text-align:center;color:#6ee7b7;\">'+r.pressure.toFixed(1)+'</td>';\n  html += '<td style=\"padding:5px 8px;text-align:center;color:'+lc+';\">'+Math.round(r.light_level)+'</td>';\n  html += '</tr>';\n});\nhtml += '</tbody></table>';\n\nreturn [\n  [{payload: latest.temperature}],\n  [{payload: latest.humidity}],\n  [{payload: latest.pressure}],\n  [{payload: latest.light_level}],\n  [makeChart('temperature','Temp \u00b0C')],\n  [makeChart('pressure','Pressure hPa')],\n  [{payload: html}]\n];",
    "outputs": 7,
    "x": 670,
    "y": 80,
    "wires": [
      [
        "n_g_temp"
      ],
      [
        "n_g_hum"
      ],
      [
        "n_g_press"
      ],
      [
        "n_g_light"
      ],
      [
        "n_c_temphum"
      ],
      [
        "n_c_presslight"
      ],
      [
        "n_table"
      ]
    ]
  },
