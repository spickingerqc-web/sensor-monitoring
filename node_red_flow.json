[
  {
    "id": "tab1",
    "type": "tab",
    "label": "Sensor Monitor"
  },
  {
    "id": "n_inject",
    "type": "inject",
    "z": "tab1",
    "name": "Every 2s",
    "repeat": "2",
    "once": true,
    "onceDelay": 0.5,
    "payload": "",
    "payloadType": "date",
    "x": 100,
    "y": 80,
    "wires": [
      [
        "n_setquery"
      ]
    ]
  },
  {
    "id": "n_setquery",
    "type": "function",
    "z": "tab1",
    "name": "Set Query",
    "func": "msg.topic='SELECT timestamp,temperature,humidity,pressure,light_level FROM sensor_data ORDER BY id DESC LIMIT 30';\nreturn msg;",
    "outputs": 1,
    "x": 290,
    "y": 80,
    "wires": [
      [
        "n_mysql"
      ]
    ]
  },
  {
    "id": "n_mysql",
    "type": "mysql",
    "z": "tab1",
    "name": "sensor_db",
    "mydb": "n_dbconfig",
    "x": 480,
    "y": 80,
    "wires": [
      [
        "n_format"
      ]
    ]
  },
  {
    "id": "n_format",
    "type": "function",
    "z": "tab1",
    "name": "Format All",
    "func": "var rows = msg.payload;\nif (!rows || rows.length === 0) return null;\nvar latest = rows[0];\nvar sorted = rows.slice().reverse();\nfunction makeChart(field, label) {\n  return { payload: [{ series:[label], data:[sorted.map(function(r){\n    return { x: new Date(r.timestamp).getTime(), y: r[field] };\n  })], labels:[label] }] };\n}\nreturn [\n  [{payload: latest.temperature}],\n  [{payload: latest.humidity}],\n  [{payload: latest.pressure}],\n  [{payload: latest.light_level}],\n  [makeChart('temperature','Temp \u00b0C')],\n  [makeChart('pressure','Pressure hPa')],\n  [{payload: latest}],\n  [{payload: rows}]\n];",
    "outputs": 8,
    "x": 670,
    "y": 80,
    "wires": [
      [
        "n_g_temp"
      ],
      [
        "n_g_hum"
      ],
      [
        "n_g_press"
      ],
      [
        "n_g_light"
      ],
      [
        "n_c_temphum"
      ],
      [
        "n_c_presslight"
      ],
      [
        "n_card"
      ],
      [
        "n_table"
      ]
    ]
  },
